{
  "name": "ocaml-forester",
  "build": {
    "context": "..",
    "dockerfile": "../docker/Dockerfile.dev"
  },
  "remoteEnv": {
    "OPAMYES": "1"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ocamllabs.ocaml-platform",
        "rust-lang.rust-analyzer",
        "haskell.haskell"
      ]
    }
  }
}
