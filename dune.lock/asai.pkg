(version 0.3.1)

(build
 (progn
  (when
   %{pkg-self:dev}
   (run dune subst))
  (run dune build -p %{pkg-self:name} -j %{jobs} @install)))

(depends dune ocaml algaeff bwd)

(source
 (fetch
  (url https://github.com/RedPRL/asai/archive/refs/tags/0.3.1.tar.gz)
  (checksum md5=07d2bc322d4da2c3f261205b021d7e8d)))
