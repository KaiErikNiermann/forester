FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV OPAMYES=1
ENV PATH="/root/.cargo/bin:${PATH}"

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bubblewrap \
    build-essential \
    cabal-install \
    curl \
    git \
    ghc \
    libgmp-dev \
    m4 \
    opam \
    pkg-config \
    python3 \
    python3-pip \
    unzip \
    zlib1g-dev \
  && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --break-system-packages reuse

RUN curl -fsSL https://sh.rustup.rs | sh -s -- -y --profile minimal

RUN cargo install just topiary-cli

WORKDIR /workspaces/ocaml-forester
